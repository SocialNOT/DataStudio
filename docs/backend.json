
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Dataset": {
      "title": "Dataset",
      "description": "A collection of processed knowledge sources.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "description": { "type": "string" },
        "currentVersion": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "DatasetVersion": {
      "title": "Dataset Version",
      "description": "A specific snapshot/version of a dataset.",
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "datasetId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "archived"] },
        "chunkCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["version", "datasetId"]
    },
    "Chunk": {
      "title": "Knowledge Chunk",
      "description": "A semantically coherent unit of text with metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "datasetId": { "type": "string" },
        "version": { "type": "string" },
        "text": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "topic": { "type": "string" },
            "keyConcepts": { "type": "array", "items": { "type": "string" } },
            "author": { "type": "string" },
            "source": { "type": "string" },
            "language": { "type": "string" },
            "period": { "type": "string" },
            "domain": { "type": "string" }
          }
        }
      },
      "required": ["id", "text"]
    },
    "GraphNode": {
      "title": "Graph Node",
      "description": "A semantic entity extracted from the text.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "label"]
    },
    "GraphEdge": {
      "title": "Graph Edge",
      "description": "A relationship between two semantic entities.",
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "relation": { "type": "string" }
      },
      "required": ["source", "target", "relation"]
    }
  },
  "auth": {
    "providers": ["anonymous", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document storage."
    },
    "/datasets/{datasetId}": {
      "schema": "Dataset",
      "description": "Dataset root metadata."
    },
    "/datasets/{datasetId}/versions/{versionId}": {
      "schema": "DatasetVersion",
      "description": "Dataset version tracking."
    },
    "/datasets/{datasetId}/versions/{versionId}/chunks/{chunkId}": {
      "schema": "Chunk",
      "description": "Individual knowledge units for RAG/Training."
    },
    "/datasets/{datasetId}/versions/{versionId}/graph": {
      "schema": "GraphNode",
      "description": "Knowledge graph metadata for a specific version."
    }
  }
}
